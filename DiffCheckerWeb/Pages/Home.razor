@page "/"
@using System.Text
@using System.Text.RegularExpressions
@using DiffCheckerLib
@using DiffCheckerLib.Enum
@using DiffCheckerLib.Interface
@using DiffCheckerLib.Setting
@inject IJSRuntime JS

<PageTitle>STB-DiffChecker Web</PageTitle>

<h3>STB-DiffChecker Web <small class="text-muted fs-6">(ST-Bridge 2.0.1 / 2.0.2 / 2.1)</small></h3>
<p class="text-muted">
    2つのST-Bridgeファイルをブラウザ内で比較します。ファイルはサーバーに送信されません。
    バージョンはファイルから自動判別します（A・Bは同一バージョンである必要があります）。
</p>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <label class="form-label fw-bold">ファイルA (.stb)</label>
        <InputFile class="form-control" OnChange="@(e => OnFileSelected(e, true))" accept=".stb,.xml" />
        @if (fileNameA != null)
        {
            <div class="small mt-1">@fileNameA @(stbA != null ? $"✓ 読込済 ({versionA})" : "")</div>
        }
        @if (loadErrorsA.Count > 0)
        {
            <details class="small text-danger"><summary>検証メッセージ @loadErrorsA.Count 件</summary>
                <ul>@foreach (string err in loadErrorsA.Take(50)) { <li>@err</li> }</ul>
            </details>
        }
    </div>
    <div class="col-md-6">
        <label class="form-label fw-bold">ファイルB (.stb)</label>
        <InputFile class="form-control" OnChange="@(e => OnFileSelected(e, false))" accept=".stb,.xml" />
        @if (fileNameB != null)
        {
            <div class="small mt-1">@fileNameB @(stbB != null ? $"✓ 読込済 ({versionB})" : "")</div>
        }
        @if (loadErrorsB.Count > 0)
        {
            <details class="small text-danger"><summary>検証メッセージ @loadErrorsB.Count 件</summary>
                <ul>@foreach (string err in loadErrorsB.Take(50)) { <li>@err</li> }</ul>
            </details>
        }
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <details>
            <summary class="fw-bold">許容差設定</summary>
            <table class="table table-sm w-auto mt-2">
                <thead><tr><th>対象</th><th>基準点</th><th>オフセット</th></tr></thead>
                <tbody>
                    @foreach (UserTolerance tol in engine.Tolerance.Tolerances())
                    {
                        <tr>
                            <td>@tol.Name</td>
                            <td><input type="number" class="form-control form-control-sm" style="width:8em" @bind="tol.Node" /></td>
                            <td><input type="number" class="form-control form-control-sm" style="width:8em" @bind="tol.Offset" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </details>
    </div>
    <div class="col-md-6">
        <details>
            <summary class="fw-bold">設定ファイル(csv)読込み（許容差・重要度）</summary>
            <InputFile class="form-control mt-2" OnChange="OnSettingCsvSelected" accept=".csv" />
            @if (settingMessage != null)
            {
                <div class="small mt-1">@settingMessage</div>
            }
        </details>
    </div>
</div>

<div class="mb-3">
    <button class="btn btn-primary" disabled="@(stbA == null || stbB == null || running)" @onclick="RunCompare">実行</button>
    @if (running)
    {
        <span class="ms-2 spinner-border spinner-border-sm"></span> <span>@(progressText ?? "比較中...")</span>
    }
    @if (errorMessage != null)
    {
        <div class="alert alert-danger mt-2">@errorMessage</div>
    }
</div>

@if (results != null)
{
    <hr />
    <h5>概要 <small class="text-muted fs-6">(ST-Bridge @engine.Version)</small></h5>
    <table class="table table-sm table-bordered w-auto">
        <thead>
            <tr><th>タブ</th><th>要素数A</th><th>要素数B</th><th>一致</th><th>許容差内</th><th>不一致</th><th>比較対象なし</th></tr>
        </thead>
        <tbody>
            @foreach (SummaryRow row in summaryRows)
            {
                SummaryRow current = row;
                <tr>
                    <td><a href="" @onclick="() => SelectTab(current.Root)" @onclick:preventDefault>@current.Header</a></td>
                    <td>@current.CountA</td>
                    <td>@current.CountB</td>
                    <td>@current.Consistent</td>
                    <td>@current.AlmostMatch</td>
                    <td>@current.Inconsistent</td>
                    <td>@current.NotComparable</td>
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-outline-secondary btn-sm mb-3" @onclick="ExportCsv">結果をCSV出力</button>

    <h5>結果詳細</h5>
    <div class="mb-2">
        <select class="form-select w-auto d-inline-block" @bind="SelectedTabBound">
            @foreach ((string root, string header) in tabs)
            {
                if (results.ContainsKey(root))
                {
                    <option value="@root">@header</option>
                }
            }
        </select>
        <span class="ms-3">
            @foreach (Consistency c in allConsistencies)
            {
                Consistency consistency = c;
                <label class="me-2">
                    <input type="checkbox" checked="@filterConsistency.Contains(consistency)"
                           @onchange="e => ToggleConsistency(consistency, (bool)e.Value!)" /> @consistency.ToJapanese()
                </label>
            }
        </span>
        <span class="ms-3">
            重要度:
            <select class="form-select form-select-sm w-auto d-inline-block" @bind="FilterImportanceBound">
                <option value="">すべて</option>
                <option value="高">高</option>
                <option value="中">中</option>
                <option value="低">低</option>
                <option value="対象外">対象外</option>
            </select>
        </span>
        <input class="form-control form-control-sm w-auto d-inline-block ms-3" placeholder="検索(XMLパス・キー)" value="@searchText" @oninput="OnSearchInput" />
    </div>

    @if (selectedTab != null)
    {
        <div class="small text-muted mb-1">
            @filteredRecords.Count / @currentTabTotal 件
            @if (filteredRecords.Count > MaxDisplayRows)
            {
                <span class="text-warning">（表示は先頭 @MaxDisplayRows 件まで。フィルタで絞り込むかCSV出力をご利用ください）</span>
            }
        </div>
        <div style="height: 60vh; overflow-y: auto;">
            <table class="table table-sm table-bordered table-hover" style="table-layout:fixed; word-break:break-all;">
                <thead class="sticky-top bg-white">
                    <tr>
                        <th style="width:24%">XMLパス</th>
                        <th style="width:22%">比較対象を決定した情報</th>
                        <th style="width:14%">要素・属性</th>
                        <th style="width:12%">ファイルA</th>
                        <th style="width:12%">ファイルB</th>
                        <th style="width:8%">比較結果</th>
                        <th style="width:6%">重要度</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Record record in filteredRecords.Take(MaxDisplayRows))
                    {
                        <tr class="@RowClass(record)">
                            <td class="small">@record.XmlPath</td>
                            <td class="small">@record.Key</td>
                            <td class="small">@record.Item</td>
                            <td class="small">@record.A</td>
                            <td class="small">@record.B</td>
                            <td class="small">@record.Consistency.ToJapanese()</td>
                            <td class="small">@record.Importance.ToJapanese()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private const long MaxFileSize = 512L * 1024 * 1024;
    private const int MaxDisplayRows = 3000;

    private VersionEngine engine = VersionEngine.Create("2.1.0")!;

    private string? fileNameA;
    private string? fileNameB;
    private string? versionA;
    private string? versionB;
    private IST_BRIDGE? stbA;
    private IST_BRIDGE? stbB;
    private List<string> loadErrorsA = [];
    private List<string> loadErrorsB = [];

    private string? settingMessage;
    private string? errorMessage;
    private string? progressText;
    private bool running;

    private Dictionary<string, List<Record>>? results;
    private IReadOnlyList<(string, string)> tabs = [];
    private string? selectedTab;

    /// <summary>概要テーブルの1行（比較完了時に1回だけ集計してキャッシュ）</summary>
    private sealed record SummaryRow(string Root, string Header, int CountA, int CountB,
        int Consistent, int AlmostMatch, int Inconsistent, int NotComparable);

    private List<SummaryRow> summaryRows = [];

    // フィルタ適用済みレコードのキャッシュ（フィルタ条件が変わった時だけ再計算する）
    private List<Record> filteredRecords = [];
    private int currentTabTotal;
    private CancellationTokenSource? searchDebounce;

    private string? SelectedTabBound
    {
        get => selectedTab;
        set { selectedTab = value; RefreshFiltered(); }
    }

    private string FilterImportanceBound
    {
        get => filterImportance;
        set { filterImportance = value; RefreshFiltered(); }
    }

    private void SelectTab(string root)
    {
        selectedTab = root;
        RefreshFiltered();
    }

    /// <summary>
    /// 検索入力はデバウンスし、入力が止まってからフィルタを実行する
    /// </summary>
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";
        searchDebounce?.Cancel();
        searchDebounce = new CancellationTokenSource();
        try
        {
            await Task.Delay(300, searchDebounce.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }
        RefreshFiltered();
        StateHasChanged();
    }

    private void RefreshFiltered()
    {
        if (results != null && selectedTab != null && results.TryGetValue(selectedTab, out List<Record>? records))
        {
            currentTabTotal = records.Count;
            filteredRecords = Filtered(records);
        }
        else
        {
            currentTabTotal = 0;
            filteredRecords = [];
        }
    }

    private void BuildSummary()
    {
        summaryRows = [];
        if (results == null)
        {
            return;
        }

        foreach ((string root, string header) in tabs)
        {
            if (!results.TryGetValue(root, out List<Record>? records))
            {
                continue;
            }

            int consistent = 0, almost = 0, inconsistent = 0, notComparable = 0;
            foreach (Record r in records)
            {
                switch (r.Consistency)
                {
                    case Consistency.Consistent: consistent++; break;
                    case Consistency.AlmostMatch: almost++; break;
                    case Consistency.Inconsistent: inconsistent++; break;
                    default: notComparable++; break;
                }
            }

            summaryRows.Add(new SummaryRow(root, header,
                VersionEngine.CountElements(stbA, root), VersionEngine.CountElements(stbB, root),
                consistent, almost, inconsistent, notComparable));
        }
    }

    private static readonly Consistency[] allConsistencies =
    [
        Consistency.Consistent,
        Consistency.AlmostMatch,
        Consistency.Inconsistent,
        Consistency.Incomparable,
        Consistency.ElementIncomparable,
    ];
    private HashSet<Consistency> filterConsistency = [.. allConsistencies];
    private string filterImportance = "";
    private string searchText = "";

    protected override void OnInitialized()
    {
        tabs = engine.Importance.GetTabs();
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e, bool isA)
    {
        errorMessage = null;
        results = null;
        try
        {
            using MemoryStream ms = new();
            await e.File.OpenReadStream(MaxFileSize).CopyToAsync(ms);
            byte[] bytes = ms.ToArray();

            string head = Encoding.UTF8.GetString(bytes, 0, Math.Min(bytes.Length, 2000));
            Match m = Regex.Match(head, @"<ST_BRIDGE[^>]*\sversion=""([^""]+)""");
            string version = m.Success ? m.Groups[1].Value : "不明";
            if (!VersionEngine.SupportedVersions.Contains(version))
            {
                errorMessage = $"{e.File.Name} のバージョン ({version}) は未対応です。対応バージョン: {string.Join(" / ", VersionEngine.SupportedVersions)}";
                return;
            }

            // A・Bでバージョンが異なる場合はエラー
            string? otherVersion = isA ? versionB : versionA;
            if (otherVersion != null && otherVersion != version)
            {
                errorMessage = $"ファイルA ({(isA ? version : otherVersion)}) とファイルB ({(isA ? otherVersion : version)}) のバージョンが一致していません。";
                return;
            }

            // バージョンに応じたエンジンに切り替え
            if (engine.Version != version)
            {
                engine = VersionEngine.Create(version)!;
                tabs = engine.Importance.GetTabs();
                settingMessage = null;
            }

            using MemoryStream readMs = new(bytes);
            (IST_BRIDGE stb, List<string> errors) = engine.LoadFile(readMs);

            if (isA)
            {
                fileNameA = e.File.Name; versionA = version; stbA = stb; loadErrorsA = errors;
            }
            else
            {
                fileNameB = e.File.Name; versionB = version; stbB = stb; loadErrorsB = errors;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"{e.File.Name} の読み込みに失敗しました: {ex.Message}";
        }
    }

    private async Task OnSettingCsvSelected(InputFileChangeEventArgs e)
    {
        try
        {
            using MemoryStream ms = new();
            await e.File.OpenReadStream(MaxFileSize).CopyToAsync(ms);
            string text = DecodeText(ms.ToArray());
            string[] lines = text.Replace("\r\n", "\n").Split('\n');

            List<string> csvTolerance = [];
            List<string> csvImportance = [];
            int flag = 0;
            foreach (string line in lines)
            {
                if (string.IsNullOrWhiteSpace(line)) { continue; }
                string headWord = line.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries)[0].Trim();
                if (headWord == "<Tolerance>") { flag = 1; continue; }
                if (headWord == "<Importance>") { flag = 2; continue; }
                if (flag == 1) { csvTolerance.Add(line); }
                else if (flag == 2) { csvImportance.Add(line); }
            }

            engine.Tolerance.ImportCsv(csvTolerance);
            List<string> unknown = engine.Importance.ImportCsv(csvImportance);
            settingMessage = $"読込み完了（許容差 {csvTolerance.Count} 行、重要度 {csvImportance.Count} 行"
                + (unknown.Count > 0 ? $"、未対応パス {unknown.Count} 件" : "") + "）";
        }
        catch (Exception ex)
        {
            settingMessage = $"設定ファイルの読み込みに失敗しました: {ex.Message}";
        }
    }

    private static string DecodeText(byte[] bytes)
    {
        try
        {
            return new UTF8Encoding(false, throwOnInvalidBytes: true).GetString(bytes);
        }
        catch (DecoderFallbackException)
        {
            return Encoding.GetEncoding("shift_jis").GetString(bytes);
        }
    }

    private async Task RunCompare()
    {
        if (stbA == null || stbB == null) { return; }
        running = true;
        errorMessage = null;
        progressText = "比較中...";
        StateHasChanged();
        await Task.Delay(30); // スピナー描画のため一度UIに制御を返す

        try
        {
            // タブ単位で比較し、進捗を表示しながらUIに制御を返す
            Dictionary<string, Importance> importanceDict = engine.Importance.UserImportance();
            Dictionary<string, List<Record>> merged = [];
            for (int i = 0; i < tabs.Count; i++)
            {
                (string root, string header) = tabs[i];
                progressText = $"比較中... {header} ({i + 1}/{tabs.Count})";
                StateHasChanged();
                await Task.Delay(1);

                Dictionary<string, List<Record>> partial = ObjectComparer.CompareSTBridgeFiles(
                    stbA, stbB, [root], importanceDict, engine.Tolerance);
                foreach (KeyValuePair<string, List<Record>> kv in partial)
                {
                    merged[kv.Key] = kv.Value;
                }
            }

            results = merged;
            selectedTab = results.Keys.FirstOrDefault();
            BuildSummary();
            RefreshFiltered();
        }
        catch (Exception ex)
        {
            errorMessage = $"比較中にエラーが発生しました: {ex.Message}";
            results = null;
        }
        finally
        {
            running = false;
            progressText = null;
        }
    }

    private List<Record> Filtered(List<Record> records)
    {
        IEnumerable<Record> query = records.Where(r => filterConsistency.Contains(r.Consistency));
        if (!string.IsNullOrEmpty(filterImportance))
        {
            query = query.Where(r => r.Importance.ToJapanese() == filterImportance);
        }
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            query = query.Where(r =>
                (r.XmlPath?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (r.Key?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (r.Item?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
        }
        return query.ToList();
    }

    private void ToggleConsistency(Consistency c, bool enabled)
    {
        if (enabled) { _ = filterConsistency.Add(c); } else { _ = filterConsistency.Remove(c); }
        RefreshFiltered();
    }

    private static string RowClass(Record record)
    {
        return record.Consistency switch
        {
            Consistency.Inconsistent => "table-danger",
            Consistency.AlmostMatch => "table-warning",
            Consistency.Incomparable or Consistency.ElementIncomparable => "table-secondary",
            _ => "",
        };
    }

    private async Task ExportCsv()
    {
        if (results == null) { return; }
        StringBuilder sb = new();
        sb.AppendLine("タブ,XMLパス,比較対象を決定した情報,要素・属性,ファイルA,ファイルB,比較結果,重要度");
        foreach ((string root, string header) in tabs)
        {
            if (!results.TryGetValue(root, out List<Record>? records)) { continue; }
            foreach (Record r in records)
            {
                sb.AppendLine(string.Join(",",
                    Csv(header), Csv(r.XmlPath), Csv(r.Key), Csv(r.Item), Csv(r.A), Csv(r.B),
                    Csv(r.Consistency.ToJapanese()), Csv(r.Importance.ToJapanese())));
            }
        }
        string name = $"STB-DiffChecker_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("downloadFileFromText", name, sb.ToString());
    }

    private static string Csv(string? value)
    {
        if (value == null) { return string.Empty; }
        return value.Contains(',') || value.Contains('"') || value.Contains('\n')
            ? "\"" + value.Replace("\"", "\"\"") + "\""
            : value;
    }
}
